<Window x:Class="FileExplorer.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Background>
        <SolidColorBrush Color="#FF2A2A3E" Opacity="0"/>
    </Window.Background>

    <Border Background="{DynamicResource SurfaceVariantBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="TitleText"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" x:Name="PromptText"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>

            <TextBox Grid.Row="2" x:Name="InputBox"
                     Margin="0,0,0,16"
                     KeyDown="InputBox_KeyDown"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel" Width="75" Margin="0,0,8,0"
                        Style="{DynamicResource IconButtonStyle}"
                        Click="Cancel_Click"/>
                <Button Content="OK" Width="75"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="OK_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
